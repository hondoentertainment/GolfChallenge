# PostgreSQL (Neon)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Admin user (auto-promoted on registration)
ADMIN_EMAIL=hondo4185@gmail.com

# JWT secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-secret-key-here

# Resend (optional - emails logged to console without this)
RESEND_API_KEY=re_xxxxx
FROM_EMAIL=Golf Challenge <noreply@yourdomain.com>

# App URL (for email links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Vercel Cron secret (optional - secures cron endpoints)
CRON_SECRET=your-cron-secret
